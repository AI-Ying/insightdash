# InsightDash Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Local PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/insightdash"
#
# Render PostgreSQL:
# Get the "Internal Database URL" from Render dashboard > your Postgres instance
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# =============================================================================
# NEXTAUTH AUTHENTICATION (Required)
# =============================================================================
# For local development:
NEXTAUTH_URL="http://localhost:3000"
# For production (change to your domain):
# NEXTAUTH_URL="https://insightdash-faa2.onrender.com"

# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# =============================================================================
# OAUTH PROVIDERS (Optional - at least one needed for OAuth login)
# =============================================================================
# GitHub OAuth App:
# 1. Go to https://github.com/settings/developers
# 2. New OAuth App
# 3. Homepage URL: http://localhost:3000 (dev) or your domain (prod)
# 4. Authorization callback URL: http://localhost:3000/api/auth/callback/github (dev)
#    or https://your-domain.com/api/auth/callback/github (prod)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth App (alternative):
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID
GOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
